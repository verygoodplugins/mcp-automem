{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "mcp__.*__store_memory",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/automem-track-store.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/automem-stop-nudge.sh\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|clear",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/automem-session-start.sh\""
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "mcp__memory__store_memory",
      "mcp__memory__recall_memory",
      "mcp__memory__associate_memories",
      "mcp__memory__update_memory",
      "mcp__memory__delete_memory",
      "mcp__memory__check_database_health"
    ]
  }
}
