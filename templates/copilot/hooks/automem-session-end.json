{
  "version": 1,
  "hooks": {
    "sessionEnd": [
      {
        "type": "command",
        "bash": "bash \"$HOME/.copilot/scripts/queue-cleanup.sh\"",
        "powershell": "powershell -ExecutionPolicy Bypass -File \"$HOME/.copilot/scripts/queue-cleanup.ps1\"",
        "timeoutSec": 15
      },
      {
        "type": "command",
        "bash": "bash \"$HOME/.copilot/scripts/session-memory.sh\"",
        "powershell": "powershell -ExecutionPolicy Bypass -File \"$HOME/.copilot/scripts/session-memory.ps1\"",
        "timeoutSec": 30
      }
    ]
  }
}
